# ============================================
# CognitiveTwin-Autism — .gitignore
# Flask Backend + React Frontend + ML Models
# ============================================

# ── Python / Flask Backend ──────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
ENV/
.venv/
flask-backend/venv/

# Flask specific
instance/
.webassets-cache
flask_session/

# Environment variables (NEVER push this!)
.env
.env.local
.env.production
*.env
flask-backend/.env

# Database files
*.db
*.sqlite
*.sqlite3
data.json

# ML Models (large binary files — use Git LFS if needed)
flask-backend/models/*.pkl
flask-backend/models/*.h5
flask-backend/models/*.pt
flask-backend/models/*.pth
flask-backend/models/*.joblib
flask-backend/ml/__pycache__/

# ── React / Node Frontend ───────────────────
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/dist/
frontend/build/

# Vite cache
frontend/.vite/
node_modules/

# Package lock (optional — remove if you want to commit it)
# frontend/package-lock.json

# ── IDE / Editor ────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip-delete-this-directory.txt

# ── OS Files ────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Testing ─────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/

# ── Misc ────────────────────────────────────
*.zip
*.tar.gz
*.rar